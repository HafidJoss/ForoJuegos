# ========== RAILWAY ENVIRONMENT CONFIGURATION EXAMPLE ==========
# Copiar este archivo a .env y actualizar con valores reales

# ========== Database Configuration ==========
# Esta variable se genera automáticamente en Railway cuando agregas PostgreSQL
# Pero aquí está el formato para referencia:
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/nuevoforo

# O configurar manualmente:
ConnectionStrings__DefaultConnection=Host=localhost;Database=NuevoForo;Username=postgres;Password=tu_contraseña_aqui

# ========== JWT Configuration ==========
# Genera una clave segura (mínimo 32 caracteres)
Jwt__Issuer=NuevoForo
Jwt__Audience=NuevoForo
Jwt__SigningKey=esta_es_una_clave_muy_larga_y_segura_con_mas_de_32_caracteres
Jwt__ExpirationMinutes=60

# ========== Rate Limiting Configuration ==========
RateLimiting__Global__PermitLimit=100
RateLimiting__Global__WindowSeconds=60
RateLimiting__Auth__PermitLimit=10
RateLimiting__Auth__WindowSeconds=60

# ========== Application Settings ==========
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# ========== Logging ==========
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft=Warning
Logging__LogLevel__NuevoForo=Information

# ========== CORS ==========
# Railway asignará automáticamente el dominio, actualizar según sea necesario
AllowedHosts=*
